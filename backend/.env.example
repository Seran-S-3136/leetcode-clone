# Backend Server Configuration
PORT=5000

# Execution Engine API
PISTON_API_URL=https://emscripten.piston.rs/api/v2/execute

# Firebase Admin Credentials (from your service account / GCP project)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@project.iam.gserviceaccount.com
# Note: In cloud dashboards (Render, Railway), paste your private key exactly with or without \n replacement
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
